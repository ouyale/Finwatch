# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# MLflow — where experiment tracking data is stored
# Local (default): leave blank, mlruns/ folder is used
# Remote: set to your MLflow server URL
MLFLOW_TRACKING_URI=

# API
API_HOST=0.0.0.0
API_PORT=8000

# Model artefact location
ARTEFACT_DIR=data/processed

# ONS API (no key needed — it's a public API)
ONS_CACHE_TTL_HOURS=24
